# Server Configuration
PORT=8000
DEBUG=True
API_V1_STR=/api/v1

# Database Configuration
DATABASE_URL=sqlite:///./vibe_marketing.db

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# X AI API Configuration (Optional)
XAI_API_KEY=your-xai-api-key
XAI_API_URL=https://api.x.ai/v1
XAI_MODEL=your-xai-model  # e.g., "grok-2"
X_ANALYSIS_PROVIDER=mock  # Options: "mock" or "xai"

# X (Twitter) API Configuration (Optional)
X_BEARER_TOKEN=your-x-bearer-token

# Exa API Configuration (Optional)
EXA_API_KEY=your-exa-api-key

# Redis Configuration (for caching, Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Frontend Configuration
FRONTEND_URL=http://localhost:5173